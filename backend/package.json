{
  "name": "itinera-api",
  "version": "2.7.5",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "node dist/db/migrate.js",
    "seed:admin": "node dist/seeds/admin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "11.0.0",
    "@node-rs/argon2": "2.0.2",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
